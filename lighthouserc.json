{
  "ci": {
    "collect": {
      "url": [
        "https://sravankacha.com/",
        "https://sravankacha.com/about/",
        "https://sravankacha.com/projects/",
        "https://sravankacha.com/resume/",
        "https://sravankacha.com/lab/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "canonical": ["error", { "minScore": 1 }],
        "is-crawlable": ["error", { "minScore": 1 }],
        "robots-txt": ["error", { "minScore": 1 }],

        "legacy-javascript": "off",
        "legacy-javascript-insight": "off",
        "unused-javascript": "off",
        "network-dependency-tree-insight": "off",
        "render-blocking-insight": "off",
        "cls-culprits-insight": "warn",
        "uses-long-cache-ttl": "off",
        "cache-insight": "off",
        "mainthread-work-breakdown": "warn",
        "max-potential-fid": "warn",
        "speed-index": "warn",
        "interactive": "warn",
        "cumulative-layout-shift": "warn",
        "third-parties-insight": "off",
        "duplicated-javascript-insight": "off",
        "font-display-insight": "off",
        "csp-xss": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
